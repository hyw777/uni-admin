{
    "bsonType": "object",
    "required": [
        "name",
        "price",
        "categoryId",
        "status"
    ],
    "permission": {
        "read": "doc.status == 1 || 'ADMIN' in auth.permission",
        "create": "'ADMIN' in auth.permission",
        "update": "'ADMIN' in auth.permission",
        "delete": "'ADMIN' in auth.permission"
    },
    "properties": {
        "_id": {
            "description": "ID，系统自动生成"
        },
        "name": {
            "bsonType": "string",
            "title": "商品名称",
            "description": "商品名称",
            "trim": "both"
        },
        "mainImage": {
            "bsonType": "string",
            "title": "商品主图",
            "description": "商品主图地址",
            "trim": "both"
        },
        "images": {
            "bsonType": "array",
            "title": "商品图片",
            "description": "商品详情图片列表",
            "arrayType": "string"
        },
        "price": {
            "bsonType": "double",
            "title": "售价",
            "description": "商品售价"
        },
        "originalPrice": {
            "bsonType": "double",
            "title": "原价",
            "description": "商品原价"
        },
        "specialPrice": {
            "bsonType": "double",
            "title": "特殊价格",
            "description": "团购/会员等特殊价格"
        },
        "categoryId": {
            "bsonType": "string",
            "title": "分类ID",
            "description": "商品所属分类ID",
            "foreignKey": "category._id"
        },
        "subCategoryIds": {
            "bsonType": "array",
            "title": "二级分类ID",
            "description": "商品所属二级分类ID列表",
            "arrayType": "string"
        },
        "brand": {
            "bsonType": "string",
            "title": "品牌",
            "description": "商品所属品牌ID"
        },
        "space_tags": {
            "bsonType": "array",
            "title": "适用空间",
            "description": "该商品适用的房间空间，例如可以同时勾选['精选', '客餐厅']",
            "arrayType": "string",
            "enum": [
                {
                    "value": "精选",
                    "text": "精选"
                },
                {
                    "value": "客餐厅",
                    "text": "客餐厅"
                },
                {
                    "value": "卧室",
                    "text": "卧室"
                },
                {
                    "value": "儿童房",
                    "text": "儿童房"
                },
                {
                    "value": "书房",
                    "text": "书房"
                },
                {
                    "value": "灯饰",
                    "text": "灯饰"
                },
                {
                    "value": "卫浴",
                    "text": "卫浴"
                }
            ]
        },
        "sellingPoints": {
            "bsonType": "array",
            "title": "核心卖点",
            "description": "商品核心卖点标签，如：实木框架、可拆洗",
            "arrayType": "string"
        },
        "description": {
            "bsonType": "string",
            "title": "商品描述",
            "description": "商品详细描述",
            "trim": "both"
        },
        "isHot": {
            "bsonType": "bool",
            "title": "热门商品",
            "description": "是否标记为热门商品",
            "defaultValue": false
        },
        "isNew": {
            "bsonType": "bool",
            "title": "新品",
            "description": "是否标记为新品",
            "defaultValue": true
        },
        "stock": {
            "bsonType": "int",
            "title": "库存",
            "description": "商品库存数量",
            "defaultValue": 0
        },
        "sales": {
            "bsonType": "int",
            "title": "销量",
            "description": "商品销量",
            "defaultValue": 0
        },
        "status": {
            "bsonType": "int",
            "title": "状态",
            "description": "0-下架 1-上架",
            "defaultValue": 1,
            "enum": [
                {
                    "value": 0,
                    "text": "下架"
                },
                {
                    "value": 1,
                    "text": "上架"
                }
            ]
        },
        "createTime": {
            "bsonType": "timestamp",
            "description": "创建时间",
            "forceDefaultValue": {
                "$env": "now"
            }
        },
        "updateTime": {
            "bsonType": "timestamp",
            "description": "更新时间",
            "forceDefaultValue": {
                "$env": "now"
            }
        },
        "origin": {
            "bsonType": "string",
            "title": "发货地",
            "description": "例如 广东省佛山市"
        },
        "rating": {
            "bsonType": "double",
            "title": "评分",
            "description": "商品评分"
        },
        "promotion_tag": {
            "bsonType": "string",
            "title": "促销标签",
            "description": "例如 超值特卖"
        },
        "promotion_desc": {
            "bsonType": "string",
            "title": "促销描述",
            "description": "促销详情说明"
        },
        "freight_fee": {
            "bsonType": "double",
            "title": "运费",
            "description": "按金额算"
        },
        "install_fee": {
            "bsonType": "double",
            "title": "送装费",
            "description": "按金额算"
        },
        "service_tags": {
            "bsonType": "array",
            "title": "服务保障",
            "arrayType": "string"
        },
        "materials": {
            "bsonType": "string",
            "title": "材质简要"
        },
        "dimensions": {
            "bsonType": "string",
            "title": "尺寸简要"
        },
        "specs": {
            "bsonType": "array",
            "title": "规格参数组",
            "description": "规格参数多行键值对"
        },
        "pointItems": {
            "bsonType": "array",
            "title": "产品卖点介绍列表",
            "arrayType": "string"
        },
        "detailImages": {
            "bsonType": "array",
            "title": "商品详情长图说明",
            "description": "商品详情富文本中的图片数组",
            "arrayType": "string"
        },
        "serviceImages": {
            "bsonType": "array",
            "title": "服务保障长图说明",
            "description": "服务保障tab下的图片数组",
            "arrayType": "string"
        }
    }
}