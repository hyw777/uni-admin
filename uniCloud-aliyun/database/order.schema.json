{
  "bsonType": "object",
  "required": [
    "user_id",
    "total_fee",
    "status",
    "order_type"
  ],
  "permission": {
    "read": "('admin' in auth.role) || ('operator' in auth.role) || (doc.user_id == auth.uid)",
    "create": false,
    "update": "('admin' in auth.role) || ('operator' in auth.role)",
    "delete": "('admin' in auth.role) || ('operator' in auth.role)"
  },
  "properties": {
    "_id": {
      "description": "订单ID"
    },
    "user_id": {
      "bsonType": "string",
      "label": "用户ID",
      "description": "下单用户ID",
      "forceDefaultValue": {
        "$env": "uid"
      }
    },
    "order_type": {
      "bsonType": "string",
      "label": "订单类型",
      "description": "normal=普通商品 | group_online=线上团购 | group_offline=线下体验/代金券",
      "enum": [
        {
          "text": "普通商品",
          "value": "normal"
        },
        {
          "text": "线上团购",
          "value": "group_online"
        },
        {
          "text": "线下体验/代金券",
          "value": "group_offline"
        }
      ]
    },
    "items": {
      "bsonType": "array",
      "label": "商品明细",
      "description": "购买的商品/团单明细",
      "items": {
        "bsonType": "object",
        "required": [
          "item_id",
          "title",
          "price",
          "quantity",
          "image"
        ]
      }
    },
    "total_fee": {
      "bsonType": "int",
      "label": "订单金额",
      "description": "订单总金额（单位：分）"
    },
    "status": {
      "bsonType": "int",
      "label": "订单状态",
      "description": "0=待支付 1=待发货 2=已发货 3=已完成 -1=已取消",
      "enum": [
        { "text": "待支付", "value": 0 },
        { "text": "待发货", "value": 1 },
        { "text": "已发货", "value": 2 },
        { "text": "已完成", "value": 3 },
        { "text": "已取消", "value": -1 }
      ],
      "defaultValue": 0
    },
    "address": {
      "bsonType": "object",
      "label": "收货地址",
      "description": "收货人地址信息（纯线上发货使用）"
    },
    "store_id": {
      "bsonType": "string",
      "label": "核销门店ID",
      "description": "关联门店ID（到店核销使用）"
    },
    "redemption_store_name": {
      "bsonType": "string",
      "label": "核销门店",
      "description": "核销门店名称"
    },
    "redemption_store_address": {
      "bsonType": "string",
      "label": "门店地址",
      "description": "核销门店地址"
    },
    "redemption_store_mobile": {
      "bsonType": "string",
      "label": "门店电话",
      "description": "核销门店联系电话"
    },
    "create_date": {
      "bsonType": "timestamp",
      "label": "下单时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "delivery_method": {
      "bsonType": "int",
      "label": "配送方式",
      "description": "1=快递 2=大件物流 3=送货入户带安装 4=同城车队",
      "enum": [
        { "text": "快递", "value": 1 },
        { "text": "大件物流", "value": 2 },
        { "text": "送货入户带安装", "value": 3 },
        { "text": "同城车队", "value": 4 }
      ]
    },
    "logistics_company": {
      "bsonType": "string",
      "label": "快递公司",
      "description": "物流/快递公司名称"
    },
    "logistics_no": {
      "bsonType": "string",
      "label": "快递单号",
      "description": "物流单号"
    },
    "installation_status": {
      "bsonType": "int",
      "label": "安装状态",
      "description": "0=无需安装 1=待分配 2=待安装 3=已安装",
      "enum": [
        { "text": "无需安装", "value": 0 },
        { "text": "待分配", "value": 1 },
        { "text": "待安装", "value": 2 },
        { "text": "已安装", "value": 3 }
      ]
    }
  },
  "indexes": []
}
