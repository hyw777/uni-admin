{
    "bsonType": "object",
    "required": ["product_id", "sku_name", "price", "stock"],
    "permission": {
        "read": "true",
        "create": "'ADMIN' in auth.permission",
        "update": "'ADMIN' in auth.permission",
        "delete": "'ADMIN' in auth.permission"
    },
    "properties": {
        "_id": {
            "description": "ID，系统自动生成"
        },
        "product_id": {
            "bsonType": "string",
            "description": "所属商品ID",
            "foreignKey": "product._id"
        },
        "sku_name": {
            "bsonType": "string",
            "description": "SKU名称（如规格、颜色等组合）"
        },
        "image": {
            "bsonType": "string",
            "description": "SKU专属预览图"
        },
        "price": {
            "bsonType": "double",
            "description": "SKU售卖价格"
        },
        "specialPrice": {
            "bsonType": "double",
            "title": "特殊价格",
            "description": "团购/会员等特殊价格"
        },
        "stock": {
            "bsonType": "int",
            "description": "SKU库存数量",
            "defaultValue": 0
        },
        "create_date": {
            "bsonType": "timestamp",
            "description": "创建时间",
            "forceDefaultValue": {
                "$env": "now"
            }
        }
    }
}