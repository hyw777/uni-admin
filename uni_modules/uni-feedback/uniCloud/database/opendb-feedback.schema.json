{
	"bsonType": "object",
	"required": ["content"],
	"permission": {
		"create": "auth.uid != null",
		"read": true,
		"delete": false,
		"update": false
	},
	"properties": {
		"_id": {
			"description": ""
		},
		"user_id": {
			"bsonType": "string",
			"description": "",
			"foreignKey": "uni-id-users._id",
			"forceDefaultValue": {
				"$env": "uid"
			}
		},
		"create_date": {
			"bsonType": "timestamp",
			"title": "",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"content": {
			"bsonType": "string",
			"title": "",
			"componentForEdit": {
				"name": "textarea"
			},
			"trim": "right"
		},
		"imgs": {
			"bsonType": "array",
			"arrayType": "file",
			"maxLength": 6,
			"fileMediaType": "image",
			"title": ""
		},
		"is_reply": {
			"bsonType": "bool",
			"title": ""
		},
		"feedback_id": {
			"bsonType": "string",
			"title": ""
		},
		"contact": {
			"bsonType": "string",
			"title": "",
			"trim": "both"
		},
		"mobile": {
			"bsonType": "string",
			"title": "",
			"pattern": "^\\+?[0-9-]{3,20}$",
			"trim": "both"
		},
		"reply_count": {
			"permission": {
				"write": false
			},
			"bsonType": "int",
			"title": "",
			"defaultValue": 0
		}
	}
}
